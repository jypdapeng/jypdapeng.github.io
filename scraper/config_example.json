{
  "base_url": "https://example.com/",
  "keywords": ["劳动法", "民法典"],
  "output_dir": "./out",
  "output_format": "md",

  "search_url_template": "https://example.com/search?q={kw}&page={page}",
  "max_pages": 30,
  "result_link_selector": "a",

  "title_selector": "h1",
  "content_selector": "article",

  "concurrency": 6,
  "delay_min": 0.2,
  "delay_max": 0.8,
  "timeout": 20,
  "same_domain_only": true,
  "respect_robots": false,

  "url_file": null
}
